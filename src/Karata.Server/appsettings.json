{
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=app.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Keycloak": {
    "auth-server-url": "https://id.karata.app/",
    "ssl-required": "none",
    "resource": "karata-server",
    "verify-token-audience": false,
    "confidential-port": 0
  },
  "AllowedHosts": "*"
}
