@page "/game/{id:guid}/spectate"

@using System.Reactive.Disposables
@using System.Reactive.Disposables.Fluent
@using System.Reactive.Linq
@using Karata.Kit.Application.Client
@using Karata.Kit.Application.Client.Connection
@using Karata.Kit.Application.Client.State
@using Karata.Kit.Application.Store
@using Karata.Pebble.Interceptors
@using Karata.Web.Support
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@using TextCopy

@implements IDisposable

@inject ILoggerFactory LoggerFactory
@inject ISnackbar Snackbar
@inject KarataClient KarataClient
@inject NavigationManager Navigator
@inject IWebAssemblyHostEnvironment Environment

<SessionGuard Session="_session">
    <MudLoading Loading="@(_store is null)" Text="Please wait..." Class="mud-height-full pa-0">
        <MudContainer MaxWidth="MaxWidth.Large" Class="mud-height-full pa-0">
            @if (_store is not null)
            {
                <MudGrid Spacing="4" Justify="Justify.Center" Class="mb-4">
                    <MudItem xs="6">
                        <MudList T="string" Color="Color.Info">
                            <MudListSubheader>Game info</MudListSubheader>
                            @if (_store.State.Game.Pile.Any())
                            {
                                <MudListItem Icon="@GetIcon(_store.State.Game.Pile.Peek())" IconColor="@(_store.State.Game.Pile.Peek().Color is Red ? Color.Error : Color.Default)">
                                    Top card: @(_store.State.Game.Pile.Peek().Name)
                                </MudListItem>
                            }
                            @if (_store.State.Game.Pick > 0)
                            {
                                <MudListItem IconColor="Color.Warning" Icon="@Icons.Material.Rounded.PostAdd">
                                    Cards to pick: @_store.State.Game.Pick
                                </MudListItem>
                            }
                            @if (_store.State.Game.Request is not null)
                            {
                                <MudListItem Icon="@GetIcon(_store.State.Game.Request)" IconColor="@(_store.State.Game.Request.Color is Red ? Color.Error : Color.Default)">
                                    Current request: @(_store.State.Game.Request.Face is None ? _store.State.Game.Request.Suit.ToString() : _store.State.Game.Request.Name)
                                </MudListItem>
                            }
                            <MudListItem IconColor="@Color.Info" Icon="@Icons.Material.Rounded.Person">
                                Current player: @_store.State.Game.CurrentHand.Username
                            </MudListItem>
                        </MudList>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudList Color="Color.Info" SelectedValue="@_store.State.Game.CurrentHand.Id">
                            <MudListSubheader>Players</MudListSubheader>
                            @foreach (var hand in _store.State.Game.Hands)
                            {
                                <HandDisplay Hand="hand" IsAdministrator="@(hand.Player.Id == _store.State.Administrator.Id)"/>
                            }
                        </MudList>
                    </MudItem>
                </MudGrid>
            }

            @if (_turns is not null)
            {
                <MudList T="string">
                    <MudListSubheader Class="pb-4">Turns</MudListSubheader>

                    @foreach (var turn in _turns)
                    {
                        <MudListItem Value="@turn">
                            <MudText Typo="Typo.caption">@(turn.Hand.Username)</MudText>
                            <MudText Typo="Typo.body1" Class="gray-text">@GetDescription(turn)</MudText>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudContainer>
    </MudLoading>
</SessionGuard>

@code
{
    [Parameter] public Guid Id { get; set; }

    [Inject] public required IClipboard Clipboard { get; set; }

    private SpectatorConnection.Session? _session;
    private RoomStore? _store;
    private List<TurnData>? _turns;
    private readonly CompositeDisposable _subscriptions = new();

    private void OnStoreChanged(RoomData room) => StateHasChanged();

    protected override async Task OnInitializedAsync()
    {
        _turns = await KarataClient.Turns.ListAsync(Id);

        var connection = new SpectatorConnection(new Uri(Environment.BaseAddress));
        await connection.StartAsync();
        
        _session = connection.Spawn(Id, new SpectatorConnection.SessionParameters());
        _session.Events.AddHandToRoom.Subscribe(data =>
        {
            var (_, user, _) = data;
            Snackbar.Add($"{user.Username} has joined the room", Severity.Info, c => c.SnackbarVariant = Variant.Text);
        }).DisposeWith(_subscriptions);

        _session.Events.AddToRoom.Subscribe(room =>
        {
            _store = new RoomStore(room, [new LoggingInterceptor<RoomData>(LoggerFactory), new TimingInterceptor<RoomData>(LoggerFactory)]);
            _store.Changes.Subscribe(OnStoreChanged);

            _session.Events.BindRoomState(_store).DisposeWith(_subscriptions);
            OnStoreChanged(room);
        }).DisposeWith(_subscriptions);
        
        _session.Events.EndGame
            .Subscribe(result => ShowMessage(new SystemMessage { Text = result.Reason, Type = result.ReasonType }))
            .DisposeWith(_subscriptions);
        
        _session.Events.SystemMessage.Subscribe(ShowMessage).DisposeWith(_subscriptions);

        _session.Events.TurnCommitted.Subscribe(resolution =>
        {
            if (resolution.IsCardless)
            {
                ShowMessage(new() { Text = $"{resolution.Player.Username} is cardless.", Type = MessageType.Info });
            }
            if (resolution.IsLastCard)
            {
                ShowMessage(new() { Text = $"{resolution.Player.Username} is on their last card.", Type = MessageType.Warning });
            }
        }).DisposeWith(_subscriptions);
        
        _session.Events.RemoveFromRoom
            .Select(_ => Observable.FromAsync(async _ =>
            {
                _session.Dispose();
                _store!.Dispose();

                StateHasChanged();

                Navigator.NavigateTo("/game/join");
            }))
            .Concat()
            .Subscribe()
            .DisposeWith(_subscriptions);

        _session.Events.RemoveHandFromRoom
            .Subscribe(handId =>
            {
                var hand = _store!.State.Game.Hands.Find(h => h.Id == handId)!;
                Snackbar.Add($"{hand.Username} has left the room.", Severity.Info, c => c.SnackbarVariant = Variant.Text);
            })
            .DisposeWith(_subscriptions);
        
        _session.Events.TurnCommitted
            .Subscribe(resolution => { Snackbar.Add($"It is now {_store!.State.Game.Hands[resolution.CurrentTurn].Username}'s turn.", Severity.Info, c => c.SnackbarVariant = Variant.Text); })
            .DisposeWith(_subscriptions);

        _session.Events.UpdateGameStatus
            .Subscribe(status => Snackbar.Add($"The game is now {status.ToString().ToLower()}.", Severity.Info, c => c.SnackbarVariant = Variant.Text))
            .DisposeWith(_subscriptions);

        _session.Events.UpdateHandStatus.Subscribe(data =>
        {
            var (handId, status) = data;
            var hand = _store!.State.Game.Hands.Find(h => h.Id == handId)!;
            Snackbar.Add($"{hand.Username} has {status.ToString().ToLower()}.", Severity.Info, c => c.SnackbarVariant = Variant.Text);
        }).DisposeWith(_subscriptions);

        await _session.JoinRoom();
    }

    private static string GetIcon(Card card) => card.Suit switch
    {
        Spades => CardIcons.Spade,
        Hearts => CardIcons.Heart,
        Clubs => CardIcons.Club,
        Diamonds => CardIcons.Diamond,
        BlackJoker or RedJoker => Icons.Material.Rounded.TheaterComedy,
        _ => throw new ArgumentException($"Invalid suit {card.Suit}", nameof(card))
    };

    private static string GetDescription(TurnData turn)
    {
        return turn.Type switch
        {
            TurnType.Skip => "Was skipped.",
            TurnType.Void => "was skipped (away).",
            TurnType.Deal => $"Was dealt {CardCount(turn.CardsPicked.Count)}.",
            TurnType.Play => new[]
                {
                    turn.CardsPlayed.Count > 0
                        ? $"Played {CardCount(turn.CardsPlayed.Count)}"
                        : null,
                    turn.CardsPicked.Count > 0
                        ? $"Picked {CardCount(turn.CardsPicked.Count)}"
                        : null
                }.Where(x => x != null)
                .DefaultIfEmpty("Took no action")
                .Aggregate((a, b) => a + " and " + b?.ToLower()) + ".",
            _ => $"{turn.Hand.Username} performed an unknown action."
        };

        string CardCount(int num) => $"{num} {(num == 1 ? "card" : "cards")}";
    }
    
    private void ShowMessage(SystemMessage message)
    {
        var severity = message.Type switch
        {
            MessageType.Error => Severity.Error,
            MessageType.Info => Severity.Info,
            MessageType.Success => Severity.Success,
            MessageType.Warning => Severity.Warning,
            _ => throw new ArgumentException("Invalid message type.", nameof(MessageType))
        };
        Snackbar.Add(message.Text, severity, c => c.SnackbarVariant = Variant.Text);
    }

    public void Dispose()
    {
        _subscriptions.Dispose();
        _store?.Dispose();
    }
}