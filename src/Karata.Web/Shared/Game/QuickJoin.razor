@using Karata.Kit.Application.Client
<MudCard Elevation="0" Class="mb-4 pa-2">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5">Jump back in...</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudStack Row>
            <MudTextField T="string" @bind-Value="_link" Label="Game ID" Variant="Variant.Filled"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Password"
                          Placeholder="ae2f0338-9762-4f07-b771-0acf5f7f2615"/>
            <MudButton Href="@JoinLink" Color="Color.Primary" Variant="Variant.Outlined">
                <MudText>Join game</MudText>
            </MudButton>
            <MudDivider Vertical FlexItem/>
            <MudButton OnClick="CreateRoom" Color="Color.Secondary">
                @if (_loading)
                {
                    <MudProgressCircular Indeterminate Class="ms-n1" Size="Size.Small" />
                    <MudText Class="ms-2">Creating game</MudText>
                }
                else
                {
                    <MudText>Create game</MudText>
                }
            </MudButton>
        </MudStack>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public required KarataClient KarataClient { get; set; }
    [Parameter] public required NavigationManager Navigator { get; set; }
    
    private bool _loading;
    private string _link = string.Empty;

    private string JoinLink => $"/game/{_link}/play";

    private async Task CreateRoom()
    {
        try
        {
            _loading = true;
            var room = await KarataClient.Rooms.CreateAsync(new RoomRequest { Password = string.Empty });
            Navigator.NavigateTo($"/game/{room.Id.ToString()}/play");
        }
        finally
        {
            _loading = false;
        }
    }
}