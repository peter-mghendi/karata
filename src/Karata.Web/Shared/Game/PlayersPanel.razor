<MudList ReadOnly SelectedValue="@Game.CurrentHand.Id">
    @if (Subheader)
    {
        <MudListSubheader>Players</MudListSubheader>    
    }
    
    @foreach (var hand in Game.Hands)
    {
        <HandDisplay Hand="hand" IsAdministrator="@(hand.Player.Id == Room.Administrator.Id)" IsMe="@(hand.Id == Me)"
                     IsCurrent="@(Game.CurrentHand.Id == hand.Id)" Controls="Controls" 
                     OnSetAway="OnSetAway" OnVoidTurn="OnVoidTurn"/>
    }
</MudList>

@code
{
    [Parameter] public bool Controls { get; set; }

    [Parameter] public bool Subheader { get; set; }

    [Parameter] public RoomData Room { get; set; } = null!;
    
    [Parameter] public long? Me { get; set; }
    
    [Parameter] public EventCallback<long> OnSetAway { get; set; }

    [Parameter] public EventCallback<long> OnVoidTurn { get; set; }

    private GameData Game => Room.Game;
}